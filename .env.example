# Secrets for local development — do NOT commit this file.
# Copy this to .env and fill in AUTH_KEY.
# Branding is configured in config.yaml (committed).

AUTH_KEY=your-secret-passphrase

# Set this to your public URL to lock down CORS in production.
# Without it, the server allows all origins (fine for local dev, risky in production).
# Example: ALLOWED_ORIGINS=https://paste.mydomain.com
# ALLOWED_ORIGINS=
